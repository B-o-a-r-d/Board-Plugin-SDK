{
    "name": "board/plugin-sdk",
    "description": "SDK and contracts for building Board Kanban plugins (Power-Ups).",
    "type": "library",
    "license": "MIT",
    "keywords": ["board", "kanban", "plugin", "sdk"],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11 || ^12 || ^13"
    },
    "require-dev": {
        "pestphp/pest": "^3 || ^4"
    },
    "autoload": {
        "psr-4": {
            "Board\\PluginSdk\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.2.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
